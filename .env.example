# ============================================
# Site Configuration
# ============================================

# Site URL — used for canonical URLs, sitemap, RSS feed
# SITE_URL=https://yourdomain.com

# Google Analytics GA4 measurement ID
# GA_ID=G-XXXXXXXXXX


# ============================================
# AI Content Generation
# ============================================

# DeepSeek API key (required for generate-post.mjs)
# Get one at: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-...


# ============================================
# Sitemap Submission
# ============================================

# Bing API key for sitemap submission
# BING_API_KEY=...

# Google Indexing API (requires service account)
# GOOGLE_INDEXING_CLIENT_EMAIL=...
# GOOGLE_INDEXING_PRIVATE_KEY=...


# ============================================
# Cloudflare (for GitHub Actions deployment)
# ============================================

# CF_API_TOKEN=...
# CF_ACCOUNT_ID=...
