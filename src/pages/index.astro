---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import CategoryNav from "../components/CategoryNav.astro";
import Pagination from "../components/Pagination.astro";
import { getCollection } from "astro:content";
import { CATEGORIES } from "../config";

const PAGE_SIZE = 6;

const allArticles = await getCollection("articles");
allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
const articles = allArticles.slice(0, PAGE_SIZE);
const latestArticle = articles[0];
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero-gradient -mx-4 -mt-8 mb-10 rounded-none px-4 pb-10 pt-8 sm:mx-0 sm:rounded-2xl sm:px-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-2xl">
        <div class="mb-3 inline-flex items-center gap-1.5 rounded-full bg-accent-100 px-3 py-1 text-xs font-medium text-accent-700 dark:bg-accent-900 dark:text-accent-300">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-500 animate-pulse-soft"></span>
          Latest in AI automation
        </div>
        <h1 class="mb-3 text-4xl font-bold tracking-tight">
          AI Automation <span class="gradient-text">for Marketers</span>
        </h1>
        <p class="max-w-xl text-base leading-relaxed text-gray-600 dark:text-gray-400">
          Tutorials, tool comparisons, and no-code automation workflows to help
          digital marketers work smarter with AI.
        </p>
      </div>
      <div class="hidden shrink-0 sm:block">
        <div class="flex h-24 w-24 items-center justify-center rounded-2xl bg-white/60 shadow-sm backdrop-blur dark:bg-gray-800/60">
          <span class="text-4xl">🤖</span>
        </div>
      </div>
    </div>

    <!-- Category quick stats -->
    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-5">
      {CATEGORIES.map((cat) => (
        <a
          href={`/${cat.slug}`}
          class="flex items-center gap-2 rounded-lg border border-white/60 bg-white/40 px-3 py-2 text-sm transition hover:bg-white/80 dark:border-gray-700/60 dark:bg-gray-800/40 dark:hover:bg-gray-800/80"
          style={{ borderLeftColor: cat.color, borderLeftWidth: "3px" }}
        >
          <span>{cat.icon}</span>
          <span class="truncate text-xs font-medium text-gray-700 dark:text-gray-300">{cat.title}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest article highlight -->
  {latestArticle && (
    <section class="mb-10">
      <h2 class="mb-4 text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500">Latest Article</h2>
      <a
        href={`/articles/${latestArticle.slug}`}
        class="group relative block overflow-hidden rounded-xl border border-accent-200 bg-gradient-to-r from-accent-50/50 to-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md dark:border-accent-900 dark:from-accent-950/50 dark:to-gray-900"
      >
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <span class="mb-2 inline-flex items-center gap-1 text-xs font-medium text-accent-600 dark:text-accent-400">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
              New
            </span>
            <h3 class="text-lg font-semibold transition-colors group-hover:text-accent-600 dark:group-hover:text-accent-400">
              {latestArticle.data.title}
            </h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{latestArticle.data.description}</p>
          </div>
          <span class="shrink-0 text-sm font-medium text-accent-600 dark:text-accent-400">
            Read more &rarr;
          </span>
        </div>
      </a>
    </section>
  )}

  <CategoryNav />

  <section class="grid gap-6 sm:grid-cols-2">
    {articles.length === 0 && (
      <p class="col-span-full text-center text-gray-400">
        No articles yet. Check back soon.
      </p>
    )}
    {articles.map((article) => <ArticleCard article={article} key={article.slug} />)}
  </section>

  {totalPages > 1 && <Pagination base="/" page={1} {totalPages} />}
</BaseLayout>
