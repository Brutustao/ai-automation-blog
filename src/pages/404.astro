---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found">
  <section class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="mb-4 text-6xl font-bold text-gray-300">404</h1>
    <p class="mb-6 text-lg text-gray-600">
      Page not found — it may have moved or doesn't exist.
    </p>
    <a
      href="/"
      class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-gray-700"
    >
      Back to Home
    </a>
  </section>
</BaseLayout>
