---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search">
  <section class="mx-auto max-w-2xl">
    <h1 class="mb-6 text-3xl font-bold tracking-tight">Search Articles</h1>

    <div class="relative mb-8">
      <input
        id="search-input"
        type="search"
        placeholder="Search articles..."
        class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:border-gray-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
        autofocus
      />
    </div>

    <div id="results" class="space-y-4">
      <p class="text-sm text-gray-400">Type to search articles...</p>
    </div>
  </section>

  <script>
    const input = document.getElementById("search-input");
    const results = document.getElementById("results");

    let index = [];

    fetch("/search.json")
      .then((r) => r.json())
      .then((data) => {
        index = data;
        input.disabled = false;
        input.placeholder = "Search articles...";
      });

    function highlight(text, query) {
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")})`, "gi");
      return text.replace(regex, "<mark class=\"bg-yellow-200 dark:bg-yellow-800\">$1</mark>");
    }

    input.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      if (!q) {
        results.innerHTML = `<p class="text-sm text-gray-400">Type to search articles...</p>`;
        return;
      }

      const hits = index.filter(
        (a) =>
          a.title.toLowerCase().includes(q) ||
          a.description.toLowerCase().includes(q)
      );

      if (hits.length === 0) {
        results.innerHTML = `<p class="text-sm text-gray-500">No results found for "<strong>${input.value}</strong>".</p>`;
        return;
      }

      results.innerHTML = hits
        .map(
          (a) => `
          <a href="/articles/${a.slug}" class="block rounded-lg border border-gray-200 p-4 transition hover:border-gray-400 dark:border-gray-800 dark:hover:border-gray-600">
            <p class="text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400">
              ${a.category.replace(/-/g, " ")}
            </p>
            <h2 class="mt-1 text-lg font-semibold dark:text-gray-100">
              ${highlight(a.title, input.value)}
            </h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
              ${highlight(a.description, input.value)}
            </p>
            <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
              ${new Date(a.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </p>
          </a>
        `
        )
        .join("");
    });
  </script>
</BaseLayout>
