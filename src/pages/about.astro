---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CATEGORIES } from "../config";
---

<BaseLayout title="About">
  <div class="mx-auto max-w-2xl">
    <div class="mb-8 flex items-center gap-4">
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-accent-50 text-3xl dark:bg-accent-950">
        🤖
      </div>
      <div>
        <h1 class="text-3xl font-bold tracking-tight">About</h1>
        <p class="text-gray-500 dark:text-gray-400">AI Automation Hub</p>
      </div>
    </div>

    <article class="prose prose-gray dark:prose-invert">
      <p>
        AI Automation Hub helps digital marketers discover and implement AI-powered
        no-code automation workflows. We review tools, compare platforms, and
        publish step-by-step tutorials so you can spend less time on repetitive
        tasks and more time on strategy.
      </p>

      <h2>What We Cover</h2>
      <ul>
        {CATEGORIES.map((cat) => (
          <li>
            <strong>{cat.icon} {cat.title}</strong> — {cat.description}
          </li>
        ))}
      </ul>

      <h2>Affiliate Disclosure</h2>
      <p>
        Some links on this site are affiliate links. If you click and make a
        purchase, we may earn a commission at no additional cost to you. We only
        recommend tools and services we believe provide genuine value to our
        readers.
      </p>
    </article>
  </div>
</BaseLayout>
