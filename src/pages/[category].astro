---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import CategoryNav from "../components/CategoryNav.astro";
import Pagination from "../components/Pagination.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { CATEGORIES } from "../config";

const PAGE_SIZE = 6;

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allArticles = await getCollection("articles", (article) =>
  article.data.category === category.slug
);
allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
const articles = allArticles.slice(0, PAGE_SIZE);
---

<BaseLayout title={category.title} description={category.description}>
  <section class="mb-8">
    <Breadcrumb category={category.slug} />
    <div class="flex items-center gap-3 mb-2">
      <span class="text-2xl">{category.icon}</span>
      <div>
        <h1 class="text-3xl font-bold tracking-tight">{category.title}</h1>
        <p class="mt-1 max-w-2xl text-gray-600 dark:text-gray-400">{category.description}</p>
      </div>
    </div>
  </section>

  <CategoryNav activeCategory={category.slug} />

  <section class="grid gap-6 sm:grid-cols-2">
    {articles.length === 0 && (
      <p class="col-span-full text-center text-gray-400">
        No articles in this category yet. Check back soon.
      </p>
    )}
    {articles.map((article) => <ArticleCard article={article} key={article.slug} />)}
  </section>

  {totalPages > 1 && <Pagination base={`/${category.slug}/`} page={1} {totalPages} />}
</BaseLayout>
