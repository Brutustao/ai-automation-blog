---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import CategoryNav from "../components/CategoryNav.astro";
import { getCollection } from "astro:content";
import { CATEGORIES } from "../config";

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const articles = await getCollection("articles", (article) =>
  article.data.category === category.slug
);
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={category.title} description={category.description}>
  <section class="mb-8">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">{category.title}</h1>
    <p class="max-w-2xl text-gray-600">{category.description}</p>
  </section>

  <CategoryNav />

  <section class="grid gap-6 sm:grid-cols-2">
    {articles.length === 0 && (
      <p class="col-span-full text-center text-gray-400">
        No articles in this category yet. Check back soon.
      </p>
    )}
    {articles.map((article) => <ArticleCard article={article} />)}
  </section>
</BaseLayout>
