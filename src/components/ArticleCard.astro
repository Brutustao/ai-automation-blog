---
import type { CollectionEntry } from "astro:content";
import { formatCategory, formatDate } from "../utils";

export interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { slug, data } = article;
---

<a
  href={`/articles/${slug}`}
  class="block rounded-lg border border-gray-200 p-5 transition hover:border-gray-400 hover:shadow-sm dark:border-gray-800 dark:hover:border-gray-600"
>
  <article>
    {data.image && (
      <img
        src={data.image}
        alt={data.title}
        class="mb-4 h-40 w-full rounded-md object-cover"
        loading="lazy"
      />
    )}
    <p class="mb-1 text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400">
      {formatCategory(data.category)}
    </p>
    <h2 class="mb-2 text-xl font-semibold">{data.title}</h2>
    <p class="mb-3 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
      {data.description}
    </p>
    <time
      datetime={data.date.toISOString()}
      class="text-xs text-gray-400 dark:text-gray-500"
    >
      {formatDate(data.date)}
    </time>
  </article>
</a>
