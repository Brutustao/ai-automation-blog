---
import type { CollectionEntry } from "astro:content";

export interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { slug, data } = article;
const categoryTitle = data.category.replace(/-/g, " ");
---

<a
  href={`/articles/${slug}`}
  class="block rounded-lg border border-gray-200 p-5 transition hover:border-gray-400 hover:shadow-sm"
>
  <article>
    <p class="mb-1 text-xs uppercase tracking-widest text-gray-500">
      {categoryTitle}
    </p>
    <h2 class="mb-2 text-xl font-semibold">{data.title}</h2>
    <p class="mb-3 text-sm leading-relaxed text-gray-600">
      {data.description}
    </p>
    <time
      datetime={data.date.toISOString()}
      class="text-xs text-gray-400"
    >
      {data.date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </time>
  </article>
</a>
