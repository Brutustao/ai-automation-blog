---
import { CATEGORIES } from "../config";
---

<nav class="mb-8">
  <ul class="flex flex-wrap gap-2">
    <li>
      <a
        href="/"
        class="inline-block rounded-full border border-gray-300 px-4 py-1.5 text-sm font-medium text-gray-700 transition hover:border-gray-900 hover:text-gray-900"
      >
        All
      </a>
    </li>
    {CATEGORIES.map((cat) => (
      <li>
        <a
          href={`/${cat.slug}`}
          class="inline-block rounded-full border border-gray-300 px-4 py-1.5 text-sm font-medium text-gray-700 transition hover:border-gray-900 hover:text-gray-900"
        >
          {cat.title}
        </a>
      </li>
    ))}
  </ul>
</nav>
