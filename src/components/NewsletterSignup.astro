---
---

<section class="mx-auto mt-12 max-w-2xl rounded-xl border border-gray-200 bg-gradient-to-br from-accent-50 to-white p-8 text-center shadow-sm dark:border-gray-800 dark:from-accent-950/30 dark:to-gray-900">
  <h2 class="text-xl font-bold tracking-tight">Stay Ahead with AI Marketing Insights</h2>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
    Get the latest AI tools, automation workflows, and marketing strategies delivered to your inbox.
  </p>
  <form class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center" action="https://gmail.us21.list-manage.com/subscribe/post" method="POST" target="_blank">
    <input
      type="email"
      name="EMAIL"
      placeholder="Enter your email"
      required
      class="min-w-0 flex-1 rounded-lg border border-gray-300 px-4 py-2.5 text-sm transition focus:border-accent-400 focus:outline-none focus:ring-2 focus:ring-accent-100 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:focus:border-accent-500"
    />
    <button
      type="submit"
      class="rounded-lg bg-accent-600 px-6 py-2.5 text-sm font-medium text-white transition hover:bg-accent-700 dark:bg-accent-500 dark:hover:bg-accent-600"
    >
      Subscribe
    </button>
  </form>
  <p class="mt-3 text-xs text-gray-400 dark:text-gray-500">No spam. Unsubscribe anytime.</p>
</section>
