---
import type { TocEntry } from "../utils";

export interface Props {
  headings: TocEntry[];
}

const { headings } = Astro.props;
---

{headings.length >= 2 && (
  <nav class="mb-8 rounded-lg border border-gray-200 bg-gray-50 p-4 not-prose dark:border-gray-800 dark:bg-gray-900">
    <p class="mb-2 text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">On this page</p>
    <ul class="space-y-1">
      {headings.map((h) => (
        <li style={{ paddingLeft: `${(h.level - 2) * 0.75}rem` }}>
          <a
            href={`#${h.id}`}
            class="text-sm text-gray-600 transition hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
