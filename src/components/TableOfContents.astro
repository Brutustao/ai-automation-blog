---
import type { TocEntry } from "../utils";

export interface Props {
  headings: TocEntry[];
}

const { headings } = Astro.props;
---

{headings.length >= 2 && (
  <nav class="sticky top-8 not-prose">
    <div class="rounded-xl border border-gray-200 bg-white/80 p-4 shadow-sm backdrop-blur dark:border-gray-800 dark:bg-gray-900/80">
      <p class="mb-3 flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        On this page
      </p>
      <ul class="space-y-1">
        {headings.map((h) => (
          <li style={{ paddingLeft: `${(h.level - 2) * 0.75}rem` }}>
            <a
              href={`#${h.id}`}
              class="block rounded-md px-2 py-1 text-sm text-gray-600 transition hover:bg-accent-50 hover:text-accent-700 dark:text-gray-400 dark:hover:bg-accent-950 dark:hover:text-accent-300"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}
