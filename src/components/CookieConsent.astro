---
---

<div id="cookie-banner" class="fixed bottom-4 left-4 right-4 z-50 mx-auto max-w-lg rounded-xl border border-gray-200 bg-white p-4 shadow-lg backdrop-blur transition-all duration-300 dark:border-gray-700 dark:bg-gray-900" role="alert" aria-label="Cookie consent">
  <p class="text-sm text-gray-600 dark:text-gray-300">
    We use cookies for analytics and essential site functions.
    <a href="/privacy" class="font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">Learn more</a>.
  </p>
  <div class="mt-3 flex gap-2">
    <button
      id="cookie-accept"
      class="rounded-lg bg-accent-600 px-4 py-2 text-xs font-medium text-white transition hover:bg-accent-700 dark:bg-accent-500 dark:hover:bg-accent-600"
    >
      Accept
    </button>
    <button
      id="cookie-dismiss"
      class="rounded-lg border border-gray-300 px-4 py-2 text-xs font-medium text-gray-600 transition hover:bg-gray-50 dark:border-gray-600 dark:text-gray-400 dark:hover:bg-gray-800"
    >
      Dismiss
    </button>
  </div>
</div>

<script>
  (function () {
    const banner = document.getElementById("cookie-banner");
    const accept = document.getElementById("cookie-accept");
    const dismiss = document.getElementById("cookie-dismiss");

    if (localStorage.getItem("cookie-consent")) {
      banner?.remove();
    }

    function handleConsent(consent) {
      localStorage.setItem("cookie-consent", consent);
      banner?.remove();
      if (consent === "accepted") {
        localStorage.setItem("cookie-consent", "accepted");
      }
    }

    accept?.addEventListener("click", () => handleConsent("accepted"));
    dismiss?.addEventListener("click", () => handleConsent("dismissed"));
  })();
</script>
