---
import { formatCategory } from "../utils";
import { CATEGORIES } from "../config";

export interface Props {
  category: string;
  title?: string;
}

const { category, title } = Astro.props;
const cat = CATEGORIES.find((c) => c.slug === category);
---

<nav class="mb-6 text-sm not-prose" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-1.5 text-gray-400 dark:text-gray-500">
    <li>
      <a href="/" class="transition hover:text-accent-600 dark:hover:text-accent-400">Home</a>
    </li>
    <li class="select-none text-gray-300 dark:text-gray-600">/</li>
    <li>
      <a
        href={`/${category}`}
        class="transition"
        style={{ color: cat?.color }}
      >
        {cat?.icon} {formatCategory(category)}
      </a>
    </li>
    {title && (
      <>
        <li class="select-none text-gray-300 dark:text-gray-600">/</li>
        <li class="truncate text-gray-500 max-w-[200px] sm:max-w-sm dark:text-gray-400" title={title}>
          {title}
        </li>
      </>
    )}
  </ol>
</nav>
