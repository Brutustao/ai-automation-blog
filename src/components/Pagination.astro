---
export interface Props {
  base: string;
  page: number;
  totalPages: number;
}

const { base, page, totalPages } = Astro.props;
---

<nav class="mt-10 flex items-center justify-center gap-4" aria-label="Pagination">
  {page > 1 && (
    <a
      href={page === 2 ? base : `${base}page/${page - 1}/`}
      class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition hover:border-gray-900 hover:text-gray-900 dark:border-gray-700 dark:text-gray-300 dark:hover:border-gray-100 dark:hover:text-gray-100"
    >
      ← Previous
    </a>
  )}

  <span class="text-sm text-gray-500 dark:text-gray-400">
    Page {page} of {totalPages}
  </span>

  {page < totalPages && (
    <a
      href={`${base}page/${page + 1}/`}
      class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition hover:border-gray-900 hover:text-gray-900 dark:border-gray-700 dark:text-gray-300 dark:hover:border-gray-100 dark:hover:text-gray-100"
    >
      Next →
    </a>
  )}
</nav>
